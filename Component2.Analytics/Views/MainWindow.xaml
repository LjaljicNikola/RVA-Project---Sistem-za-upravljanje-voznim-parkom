<Window x:Class="Component2.Analytics.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fleet Analytics — Component 2"
        Width="920" Height="660"
        MinWidth="700" MinHeight="500">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Padding="4,2"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main content -->
        <Grid Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="265"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <StackPanel Grid.Column="0">

                <TextBlock Text="Vehicle" Style="{StaticResource SectionHeader}"/>
                <ComboBox ItemsSource="{Binding Vehicles}"
                          SelectedItem="{Binding SelectedVehicle}"
                          DisplayMemberPath="LicensePlate"
                          Margin="0,0,0,4"/>
                <Button Content="↻ Refresh Vehicles"
                        Command="{Binding LoadVehiclesCommand}"
                        Padding="8,5" Margin="0,0,0,4"/>

                <TextBlock Text="Date Range" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <DatePicker Grid.Column="0" SelectedDate="{Binding DateFrom}"/>
                    <TextBlock Grid.Column="1" Text="–" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <DatePicker Grid.Column="2" SelectedDate="{Binding DateTo}"/>
                </Grid>

                <TextBlock Text="Statistical Method" Style="{StaticResource SectionHeader}"/>
                <ListBox ItemsSource="{Binding Strategies}"
                         SelectedItem="{Binding SelectedStrategy}"
                         DisplayMemberPath="Name"
                         BorderBrush="#D1D5DB"
                         Margin="0,0,0,4"/>

                <Separator Margin="0,10"/>

                <Button Content="▶  Calculate"
                        Command="{Binding CalculateCommand}"
                        Padding="8,7" Margin="0,0,0,6"
                        Background="#2563EB" Foreground="White"
                        FontWeight="SemiBold"/>

                <Button Content="⬇  Export to CSV"
                        Command="{Binding ExportCsvCommand}"
                        Padding="8,6"/>

                <Separator Margin="0,10"/>

                <!-- Result box -->
                <Border Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1"
                        CornerRadius="4" Padding="10">
                    <StackPanel>
                        <TextBlock Text="RESULT" FontSize="10" FontWeight="Bold"
                                   Foreground="#0369A1" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ResultLabel}"
                                   FontSize="13" FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#E5E7EB"/>

            <!-- Right panel: data grid -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Telemetry Records"
                           Style="{StaticResource SectionHeader}" Margin="8,0,0,4"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding TelemetryRecords}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          AlternatingRowBackground="#F9FAFB"
                          GridLinesVisibility="Horizontal"
                          Margin="6,0,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Reading Time"
                                            Binding="{Binding ReadingTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}}"
                                            Width="145"/>
                        <DataGridTextColumn Header="Distance (km)"
                                            Binding="{Binding DistanceTraveled, StringFormat=\{0:F2\}}"
                                            Width="110"/>
                        <DataGridTextColumn Header="Fuel (L/100km)"
                                            Binding="{Binding FuelConsumption, StringFormat=\{0:F2\}}"
                                            Width="110"/>
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="130"/>
                        <DataGridTextColumn Header="Vehicle ID"
                                            Binding="{Binding VehicleId}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
